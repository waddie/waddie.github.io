{:aliases {:dev  {:extra-deps   {io.github.cognitect-labs/test-runner
                                 {:git/sha "dfb30dd"
                                  :git/tag "v0.5.1"}}
                  :extra-paths  ["test" "dev"]
                  :still/config {:colour? false}}
           :run  {:exec-fn      www.core/build
                  :extra-deps   {io.github.cognitect-labs/test-runner
